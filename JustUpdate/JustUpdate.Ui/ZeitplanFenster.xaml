<Window x:Class="JustUpdate.Ui.ZeitplanFenster"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wartung planen" Width="620" Height="620"
        Icon="justupdate.ico"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent">

  <Border CornerRadius="16" Background="{StaticResource BgMain}"
          BorderBrush="#0a0a10" BorderThickness="1.5">
    <Border.Effect>
      <DropShadowEffect BlurRadius="45" ShadowDepth="0" Opacity="0.55" Color="#000" />
    </Border.Effect>

    <Grid Margin="24,18,24,22">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Margin="0,0,0,16" Background="Transparent"
            MouseLeftButtonDown="Gezogen">
        <StackPanel Orientation="Horizontal">
          <Ellipse Width="10" Height="10" Fill="{StaticResource Acc}" Margin="0,0,9,0"
                   VerticalAlignment="Center" />
          <TextBlock Text="Automatische Wartung" FontSize="16" FontWeight="Bold"
                     VerticalAlignment="Center" />
        </StackPanel>
        <Button Content="X" Style="{StaticResource Fenstertaste}"
                HorizontalAlignment="Right" Click="Schliessen" />
      </Grid>

      <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="12.5" Margin="0,0,0,16"
                 LineHeight="19" Foreground="{StaticResource FgDim}"
                 Text="JustUpdate legt eine Aufgabe in der Windows-Aufgabenplanung an und wartet den Rechner wöchentlich von allein." />

      <StackPanel Grid.Row="2">

        <!-- Auswahl: nachholen oder fester Termin -->
        <Border Background="{StaticResource BgCard}" CornerRadius="12" Padding="16,14"
                BorderBrush="{StaticResource Bdr}" BorderThickness="1" Margin="0,0,0,10">
          <StackPanel>
            <RadioButton x:Name="xNachStart" Style="{StaticResource Auswahl}"
                         GroupName="Modus" IsChecked="True">
              <StackPanel>
                <TextBlock Text="Nachholen, wenn der Rechner läuft"
                           FontSize="13.5" FontWeight="SemiBold" />
                <TextBlock TextWrapping="Wrap" FontSize="11.5" Margin="0,3,0,0"
                           LineHeight="17" Foreground="{StaticResource FgDim}"
                           Text="Empfohlen. Sobald eine Woche vergangen ist, läuft die Wartung — war der Rechner zum Termin ausgeschaltet, holt Windows sie nach dem nächsten Start nach. Es fällt nie ein Lauf aus." />
              </StackPanel>
            </RadioButton>

            <Rectangle Height="1" Fill="{StaticResource Bdr}" Margin="0,12,0,12" />

            <RadioButton x:Name="xFesterTermin" Style="{StaticResource Auswahl}"
                         GroupName="Modus">
              <StackPanel>
                <TextBlock Text="Nur zum festen Termin"
                           FontSize="13.5" FontWeight="SemiBold" />
                <TextBlock TextWrapping="Wrap" FontSize="11.5" Margin="0,3,0,0"
                           LineHeight="17" Foreground="{StaticResource FgDim}"
                           Text="Die Wartung läuft ausschliesslich zum eingestellten Zeitpunkt. War der Rechner aus, fällt der Lauf ersatzlos aus." />
              </StackPanel>
            </RadioButton>
          </StackPanel>
        </Border>

        <!-- Rhythmus -->
        <Border Background="{StaticResource BgCard}" CornerRadius="12" Padding="16,14"
                BorderBrush="{StaticResource Bdr}" BorderThickness="1">
          <StackPanel>
            <TextBlock Text="RHYTHMUS" FontSize="10.5" FontWeight="Bold"
                       Foreground="{StaticResource FgDim}" Margin="0,0,0,10" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <TextBlock Text="Wochentag" FontSize="11.5" Margin="0,0,0,6"
                           Foreground="{StaticResource FgDim}" />
                <ComboBox x:Name="xTag" Style="{StaticResource Auswahlfeld}" Height="34" />
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="Uhrzeit" FontSize="11.5" Margin="0,0,0,6"
                           Foreground="{StaticResource FgDim}" />
                <StackPanel Orientation="Horizontal">
                  <ComboBox x:Name="xStunde" Style="{StaticResource Auswahlfeld}"
                            Width="72" Height="34" />
                  <TextBlock Text=":" VerticalAlignment="Center" Margin="6,0" FontSize="15"
                             FontWeight="Bold" />
                  <ComboBox x:Name="xMinute" Style="{StaticResource Auswahlfeld}"
                            Width="72" Height="34" />
                </StackPanel>
              </StackPanel>
            </Grid>

            <TextBlock x:Name="xModulHinweis" TextWrapping="Wrap" FontSize="11"
                       Margin="0,12,0,0" LineHeight="16"
                       Foreground="{StaticResource FgMute}" />
          </StackPanel>
        </Border>
      </StackPanel>

      <Border Grid.Row="3" Background="{StaticResource BgTief}" CornerRadius="12"
              Padding="16,13" Margin="0,10,0,0"
              BorderBrush="{StaticResource Bdr}" BorderThickness="1">
        <StackPanel>
          <TextBlock Text="STATUS" FontSize="10.5" FontWeight="Bold"
                     Foreground="{StaticResource FgDim}" Margin="0,0,0,6" />
          <TextBlock x:Name="xStatus" FontSize="12" TextWrapping="Wrap" LineHeight="18"
                     Foreground="{StaticResource Fg}" />
        </StackPanel>
      </Border>

      <Grid Grid.Row="4" Margin="0,16,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="8" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Button x:Name="xEinrichten" Grid.Column="0" Content="Automatik einschalten"
                Style="{StaticResource Starttaste}" Height="44" Click="Einrichten" />
        <Button x:Name="xEntfernen" Grid.Column="2" Content="Automatik ausschalten"
                Style="{StaticResource Flachtaste}" Height="44" Click="Entfernen" />
      </Grid>
    </Grid>
  </Border>
</Window>
