<Window x:Class="JustUpdate.Ui.InfoFenster"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Was JustUpdate macht" Width="720" Height="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        AllowsTransparency="True" Background="Transparent">

  <Border CornerRadius="16" Background="{StaticResource BgMain}"
          BorderBrush="#0a0a10" BorderThickness="1.5">
    <Border.Effect>
      <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.55" Color="#000" />
    </Border.Effect>

    <Grid Margin="22,16,22,20">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Margin="0,0,0,12" Background="Transparent"
            MouseLeftButtonDown="Gezogen">
        <StackPanel Orientation="Horizontal">
          <Ellipse Width="10" Height="10" Fill="{StaticResource Acc}" Margin="0,0,8,0"
                   VerticalAlignment="Center" />
          <TextBlock Text="Was JustUpdate macht — und was nicht" FontSize="15"
                     FontWeight="Bold" VerticalAlignment="Center" />
        </StackPanel>
        <Button Content="X" Style="{StaticResource Fenstertaste}"
                HorizontalAlignment="Right" Click="Schliessen" />
      </Grid>

      <Border Grid.Row="1" Background="{StaticResource BgTief}" CornerRadius="10"
              Padding="14" Margin="0,0,0,12"
              BorderBrush="{StaticResource Bdr}" BorderThickness="1">
        <StackPanel>
          <TextBlock x:Name="xKopf" FontSize="11.5" TextWrapping="Wrap"
                     Foreground="{StaticResource FgDim}" />
          <TextBlock x:Name="xLogPfad" FontSize="10" TextWrapping="Wrap" Margin="0,6,0,0"
                     Foreground="{StaticResource FgMute}" />
        </StackPanel>
      </Border>

      <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="xModule">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="{StaticResource BgCard}" CornerRadius="10"
                      Padding="14,12" Margin="0,0,0,7"
                      BorderBrush="{StaticResource Bdr}" BorderThickness="1">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Text="{Binding Kuerzel}" Foreground="{Binding Farbe}"
                             FontSize="15" FontWeight="Bold" VerticalAlignment="Top" />

                  <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Anzeige}" FontSize="13" FontWeight="SemiBold" />

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                      <TextBlock Text="macht" FontSize="10" FontWeight="Bold" Width="62"
                                 Foreground="{StaticResource Grn}" VerticalAlignment="Top" />
                      <TextBlock Text="{Binding Macht}" FontSize="11" TextWrapping="Wrap"
                                 Foreground="{StaticResource Fg}" MaxWidth="520" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                      <TextBlock Text="macht nicht" FontSize="10" FontWeight="Bold" Width="62"
                                 Foreground="{StaticResource Amb}" VerticalAlignment="Top"
                                 TextWrapping="Wrap" />
                      <TextBlock Text="{Binding MachtNicht}" FontSize="11" TextWrapping="Wrap"
                                 Foreground="{StaticResource FgDim}" MaxWidth="520" />
                    </StackPanel>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <TextBlock Grid.Row="3" Margin="0,12,0,0" FontSize="10" TextWrapping="Wrap"
                 Foreground="{StaticResource FgMute}"
                 Text="JustUpdate — Itin TechSolutions — info@itintechsolutions.ch — Jeder Lauf wird vollständig protokolliert." />
    </Grid>
  </Border>
</Window>
