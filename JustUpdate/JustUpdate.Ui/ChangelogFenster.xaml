<Window x:Class="JustUpdate.Ui.ChangelogFenster"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JustUpdate - Patch-Notes" Width="980" Height="700"
        MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

  <Border CornerRadius="14" Background="{StaticResource BgMain}"
          BorderBrush="{StaticResource Bdr}" BorderThickness="1.5">
    <Border.Effect>
      <DropShadowEffect BlurRadius="45" ShadowDepth="0" Opacity="0.55" Color="#000" />
    </Border.Effect>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- KOPF -->
      <Border x:Name="xKopfleiste" Grid.Row="0" Padding="22,16,22,14" Background="#0e0e15"
              BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1"
              MouseLeftButtonDown="Gezogen">
        <Grid>
          <StackPanel Orientation="Horizontal">
            <Ellipse Width="10" Height="10" Fill="{StaticResource Acc}" Margin="0,0,10,0"
                     VerticalAlignment="Center" />
            <TextBlock Text="Patch-Notes" FontSize="15" FontWeight="Bold"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="xUnterzeile" FontSize="12" Margin="12,2,0,0"
                       VerticalAlignment="Center" Foreground="{StaticResource FgDim}" />
          </StackPanel>

          <Button Content="X" Style="{StaticResource Fenstertaste}"
                  HorizontalAlignment="Right" Click="Schliessen" />
        </Grid>
      </Border>

      <!-- KOERPER: Versionsliste links, Karten rechts -->
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="200" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource BgTief}"
                BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,1,0">
          <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,12,10,12">
            <StackPanel x:Name="xVersionsliste" />
          </ScrollViewer>
        </Border>

        <ScrollViewer x:Name="xKarten" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      Padding="22,16,22,16">
          <StackPanel x:Name="xInhalt" />
        </ScrollViewer>
      </Grid>

      <!-- FUSS -->
      <Border Grid.Row="2" Padding="22,12,22,14" Background="#0e0e15"
              BorderBrush="{StaticResource Bdr}" BorderThickness="0,1,0,0">
        <Grid>
          <TextBlock x:Name="xQuelle" FontSize="10.5" VerticalAlignment="Center"
                     Foreground="{StaticResource FgMute}" />
          <Button Content="Schliessen" Style="{StaticResource Flachtaste}"
                  HorizontalAlignment="Right" Height="34" Width="130"
                  IsDefault="True" IsCancel="True" Click="Schliessen" />
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
